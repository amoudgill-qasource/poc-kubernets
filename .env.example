# Django Configuration
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1

# Database Configuration (choose one approach)
# Option 1: DATABASE_URL (recommended for production)
DATABASE_URL=mysql://django_user:django_password@db:3306/ecommerce_project

# Option 2: Individual database variables
DB_ENGINE=django.db.backends.mysql
DB_NAME=ecommerce_project
DB_USER=django_user
DB_PASSWORD=django_password
DB_HOST=db
DB_PORT=3306

# MySQL Database Credentials (for docker-compose)
MYSQL_DATABASE=ecommerce_project
MYSQL_USER=django_user
MYSQL_PASSWORD=django_password
MYSQL_ROOT_PASSWORD=root_password

# Optional: Email Configuration (if you add email functionality later)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Optional: Payment Configuration (if you add payment processing later)
# STRIPE_PUBLIC_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# Optional: AWS Configuration (if you add S3 or other AWS services later)
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket-name
# AWS_S3_REGION_NAME=us-east-1
