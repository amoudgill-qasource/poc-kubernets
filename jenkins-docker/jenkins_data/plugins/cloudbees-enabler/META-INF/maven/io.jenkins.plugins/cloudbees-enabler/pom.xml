<project xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd" xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <modelVersion>4.0.0</modelVersion>
  <groupId>io.jenkins.plugins</groupId>
  <artifactId>cloudbees-enabler</artifactId>
  <version>1.43.v5b_7c0c898e84</version>
  <packaging>hpi</packaging>
  <name>CloudBees Installation Plugin</name>
  <description>Makes CloudBees Products available in Jenkins.</description>
  <url>https://github.com/jenkinsci/cloudbees-enabler-plugin</url>
  <inceptionYear>2016</inceptionYear>
  <licenses>
    <license>
      <name>The MIT license</name>
      <url>http://www.opensource.org/licenses/mit-license.php</url>
      <distribution>repo</distribution>
    </license>
  </licenses>
  <scm>
    <connection>scm:git:ssh://github.com/jenkinsci/cloudbees-enabler-plugin.git</connection>
    <developerConnection>scm:git:ssh://git@github.com/jenkinsci/cloudbees-enabler-plugin.git</developerConnection>
    <tag>5b7c0c898e84808dc8bc485ef0e0ae5656f0eb4e</tag>
    <url>https://github.com/jenkinsci/cloudbees-enabler-plugin</url>
  </scm>
  <distributionManagement>
    <repository>
      <id>maven.jenkins-ci.org</id>
      <url>https://repo.jenkins-ci.org/releases/</url>
    </repository>
    <snapshotRepository>
      <id>maven.jenkins-ci.org</id>
      <url>https://repo.jenkins-ci.org/snapshots/</url>
    </snapshotRepository>
  </distributionManagement>
  <build>
    <plugins>
      <plugin>
        <groupId>org.jenkins-ci.tools</groupId>
        <artifactId>maven-hpi-plugin</artifactId>
        <version>3.53</version>
        <extensions>true</extensions>
      </plugin>
    </plugins>
  </build>
</project>
